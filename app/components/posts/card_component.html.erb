<article id="<%= dom_id(post) %>" class="<%= card_classes %>">
  <% if card_link_url.present? %>
    <%= link_to card_link_url,
          class: "feed-post-card__overlay-link",
          aria: { label: "Open comments for this post" } do %>
      <span class="feed-post-card__overlay-text">Open comments for this post</span>
    <% end %>
  <% end %>

  <% if plain_repost? %>
    <div class="feed-post-card__reposted-by">
      <%= inline_svg_tag "icons/repost.svg", class: "feed-post-card__reposted-by-icon" %>
      <span>Reposted by</span>
      <%= link_to "@#{post.user.display_name.presence || "stardancer"}",
            profile_path(post.user.display_name),
            class: "feed-post-card__reposted-by-link" %>
    </div>
  <% end %>

  <header class="feed-post-card__header">
    <% if author.present? %>
      <%= link_to profile_path(author.display_name), class: "feed-post-card__avatar-link", aria: { label: "@#{author_name}" } do %>
        <%= image_tag author.avatar, alt: "", class: "feed-post-card__avatar" %>
      <% end %>
    <% else %>
      <span class="feed-post-card__avatar feed-post-card__avatar--placeholder" aria-hidden="true">S</span>
    <% end %>

    <div class="feed-post-card__meta">
      <p class="feed-post-card__byline">
        <% if author.present? %>
          <%= link_to "@#{author_name}", profile_path(author.display_name), class: "feed-post-card__author" %>
        <% else %>
          <span class="feed-post-card__author">@stardancer</span>
        <% end %>

        <% if project.present? %>
          <span class="feed-post-card__context">on</span>
          <%= link_to project.title, project_path(project), class: "feed-post-card__project" %>
        <% end %>

        <time class="feed-post-card__time" datetime="<%= display_post.created_at.iso8601 %>" title="<%= l(display_post.created_at, format: :long) %>">
          · <%= time_ago_in_words(display_post.created_at) %>
        </time>

        <% if show_idv_badge? %>
          <%= render IdvBadgeComponent.new(user: current_user, context: devlog? ? :devlog : :post) %>
        <% end %>
      </p>

      <% if devlog? && display_postable.respond_to?(:duration_seconds) && display_postable.duration_seconds.present? %>
        <p class="feed-post-card__duration"><%= helpers.format_seconds(display_postable.duration_seconds) %> logged</p>
      <% end %>

      <% if quote_repost? && body.present? %>
        <div class="feed-post-card__body feed-post-card__body--inline">
          <%= helpers.md(body, allow_images: false) %>
        </div>
      <% end %>
    </div>
  </header>

  <% if body.present? && !quote_repost? %>
    <div class="feed-post-card__body">
      <%= helpers.md(body, allow_images: false) %>
    </div>
  <% end %>

  <% if attachment_count.positive? %>
    <div class="feed-post-card__media">
      <div class="feed-post-card__media-viewport">
        <div class="feed-post-card__media-track">
          <% attachments.each_with_index do |attachment, index| %>
            <figure class="feed-post-card__media-slide" <%= "hidden" if index.positive? %>>
              <% if attachment.variable? %>
                <%= image_tag attachment.variant(:large), alt: "", class: "feed-post-card__image" %>
              <% elsif attachment.content_type.to_s.start_with?("image/") %>
                <%= image_tag attachment, alt: "", class: "feed-post-card__image" %>
              <% elsif attachment.content_type.to_s.start_with?("video/") %>
                <%= video_tag url_for(attachment), controls: true, class: "feed-post-card__video" %>
              <% else %>
                <%= link_to attachment.filename.to_s, url_for(attachment), class: "feed-post-card__file" %>
              <% end %>
            </figure>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if quote_repost? && original_post.present? %>
    <div class="feed-post-card__repost-preview">
      <%= render Posts::CardComponent.new(
            post: original_post,
            current_user: current_user,
            theme: :"repost-preview",
            compact: true,
            show_likes: false,
            show_comments: false,
            show_reposts: false,
            show_actions: false
          ) %>
    </div>
  <% end %>

  <% if show_footer? %>
  <footer class="feed-post-card__actions">
    <% if show_comments && interaction_post&.postable_type == "Post::Devlog" %>
      <%= link_to comment_url,
            class: "feed-post-card__action",
            aria: { label: "#{interaction_postable.comments_count} comments" } do %>
        <%= inline_svg_tag "icons/comment.svg", class: "feed-post-card__action-icon" %>
        <span id="<%= comments_count_id %>"><%= interaction_postable.comments_count %></span>
      <% end %>
    <% end %>

    <% if show_reposts %>
      <% if repostable? %>
        <div class="feed-post-card__repost">
          <% if reposted_by_current_user? %>
            <%= button_to post_repost_path(repost_target),
                  method: :delete,
                  class: "feed-post-card__action feed-post-card__action--active",
                  aria: { label: "Remove repost" },
                  form: { class: "feed-post-card__repost-form" } do %>
              <%= inline_svg_tag "icons/repost.svg", class: "feed-post-card__action-icon" %>
              <span><%= repost_count %></span>
            <% end %>
          <% elsif current_user.present? %>
            <details class="feed-post-card__repost-menu">
              <summary class="feed-post-card__action" aria-label="Repost">
                <%= inline_svg_tag "icons/repost.svg", class: "feed-post-card__action-icon" %>
                <span><%= repost_count %></span>
              </summary>

              <div class="feed-post-card__repost-panel">
                <div class="feed-post-card__repost-options" aria-label="Repost options">
                  <%= button_to post_repost_path(repost_target),
                        class: "feed-post-card__repost-option",
                        form: { class: "feed-post-card__repost-form feed-post-card__repost-form--plain" } do %>
                    Repost
                  <% end %>

                  <button type="button"
                          class="feed-post-card__repost-option"
                          onclick="this.closest('details')?.removeAttribute('open'); document.getElementById(<%= quote_dialog_id.to_json %>)?.showModal()">
                    Quote
                  </button>
                </div>
              </div>
            </details>

            <dialog id="<%= quote_dialog_id %>"
                    class="composer-modal"
                    data-controller="modal"
                    aria-label="Quote repost">
              <%= render Posts::ComposerComponent.new(
                    post: Post::Repost.new,
                    current_user: current_user,
                    projects: [],
                    selected_project: nil,
                    url: post_repost_path(repost_target),
                    scope: :post_repost,
                    aria_label: "Quote repost",
                    body_label: "Add a thought",
                    placeholder: "Add a thought before reposting.",
                    submit_text: "Quote",
                    disable_with: "Quoting...",
                    simple_mode: true,
                    show_project_chips: false,
                    show_attachments: false,
                    show_time_preview: false
                  ) %>
            </dialog>
          <% else %>
            <span class="feed-post-card__action feed-post-card__action--disabled" aria-label="Sign in to repost">
              <%= inline_svg_tag "icons/repost.svg", class: "feed-post-card__action-icon" %>
              <span><%= repost_count %></span>
            </span>
          <% end %>
        </div>
      <% else %>
        <span class="feed-post-card__action feed-post-card__action--disabled" aria-label="Only devlogs can be reposted">
          <%= inline_svg_tag "icons/repost.svg", class: "feed-post-card__action-icon" %>
          <span>0</span>
        </span>
      <% end %>
    <% end %>

    <% if show_likes && likeable.present? %>
      <div class="feed-post-card__like">
        <%= render "likes/button", likeable: likeable %>
      </div>
    <% end %>

    <% if show_actions %>
      <div class="feed-post-card__more-wrap" data-controller="post-menu" data-post-menu-url-value="<%= post_url %>">
        <button type="button" class="feed-post-card__more" aria-label="More actions" data-action="post-menu#toggle">
          <span aria-hidden="true">•••</span>
        </button>

        <div class="feed-post-card__menu" data-post-menu-target="menu" hidden>
          <% if can_edit? && edit_url.present? %>
            <%= link_to "Edit", edit_url, class: "feed-post-card__menu-item" %>
          <% end %>

          <% if can_delete? && delete_url.present? %>
            <%= button_to "Delete", delete_url,
                  method: :delete,
                  class: "feed-post-card__menu-item feed-post-card__menu-item--danger",
                  form: { class: "feed-post-card__menu-form", onsubmit: "return confirm('Are you sure you want to delete this devlog?')" } %>
          <% end %>

          <button type="button" class="feed-post-card__menu-item" data-action="post-menu#share">
            Copy link to clipboard
          </button>
        </div>
      </div>
    <% end %>
  </footer>
  <% end %>
</article>
