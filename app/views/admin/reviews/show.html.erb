<% content_for :title, "YSWS Review ##{@review.id}" %>

<main class="admin-ysws-reviews" role="main" data-controller="review-sidebar">
  <!-- Header Section -->
  <div class="review-detail-header">
    <%= link_to "← back", "/admin/review", class: "btn-back", "aria-label": "Back to review queue" %>

    <div class="header-content">
      <div class="header-left">
        <h1>YSWS Review</h1>
        <div style="display: flex; align-items: center; gap: var(--space-m);">
          <h2 class="project-name"><%= @review.project.title %></h2>
          <% if @review.reviewed_at %>
            <span class="status-done">done</span>
          <% else %>
            <span class="status-pending">pending</span>
          <% end %>
        </div>
        <% unless @review.ship_cert_id %>
          <p class="ship-event-note">This is a standalone ship event (reship)</p>
        <% end %>
      </div>

      <div class="header-actions">
        <% if @review.user %>
          <div class="submitter-card">
            <div class="submitter-avatar">
              <% display_name = @review.user.display_name || @review.user.email || "?" %>
              <%= display_name.first.upcase %>
            </div>
            <div class="submitter-info">
              <div class="submitter-name"><%= @review.user.display_name || "Unknown User" %></div>
              <div class="submitter-email"><%= @review.user.email %></div>
            </div>
          </div>
        <% end %>

        <% if @review.reviewed_at %>
          <button class="btn-action btn-undo" disabled>
            undo review
          </button>
        <% end %>

        <button class="btn-action btn-refresh" disabled>
          FORCE reload Data
        </button>

        <button class="btn-action btn-report" disabled>
          🚩 Report to Fraud Squad!
        </button>
      </div>
    </div>
  </div>

  <!-- Popup Toggle Button (only visible in popup mode) -->
  <button type="button"
          class="review-sidebar-toggle"
          data-review-sidebar-target="toggle"
          data-action="click->review-sidebar#togglePopup"
          aria-label="Toggle project details">
    Details
  </button>

  <!-- Main Content Grid -->
  <div class="review-detail-grid">
    <!-- Left Column -->
    <div class="review-detail-left">
      <!-- Ship Cert Video Section -->
      <section class="review-card video-card">
        <h3>Ship Cert Video</h3>
        <div class="video-placeholder">
          <div class="placeholder-text">Placeholder for ship cert video</div>
        </div>
      </section>

      <!-- Time Stats Section -->
      <section class="review-card stats-card">
        <h3>Time Stats</h3>
        <div class="stats-grid">
          <div class="stat-box">
            <div class="stat-label">Total Time</div>
            <div class="stat-value">
              <%= (@stats[:total_minutes] / 60.0).round(1) %>h
            </div>
          </div>
          <div class="stat-box">
            <div class="stat-label">Avg per Devlog</div>
            <div class="stat-value">
              <%= (@stats[:avg_minutes] / 60.0).round(1) %>h
            </div>
          </div>
          <div class="stat-box">
            <div class="stat-label">Longest</div>
            <div class="stat-value">
              <%= (@stats[:max_minutes] / 60.0).round(1) %>h
            </div>
          </div>
          <div class="stat-box">
            <div class="stat-label">Devlogs ≥1hr</div>
            <div class="stat-value">
              <%= @stats[:one_hour_plus_count] %>
            </div>
          </div>
        </div>
        <div class="time-chart">
          <div class="chart-title">Time Distribution Across Devlogs</div>
          <% if @review.devlog_reviews.any? %>
            <%
              chart_data = @review.devlog_reviews.each_with_index.map do |devlog_review, index|
                {
                  label: "Devlog #{index + 1}",
                  minutes: devlog_review.original_minutes || 0
                }
              end
            %>
            <div data-controller="devlog-time-chart"
                 data-devlog-time-chart-data-value="<%= chart_data.to_json %>"
                 class="d3-chart-container">
            </div>
          <% else %>
            <div class="placeholder-text">No devlogs to chart</div>
          <% end %>
        </div>
      </section>

      <!-- Boss Note Section -->
      <section class="review-card boss-note-card">
        <h3>Note from da boss of YSWS - Alex (aka AVD)</h3>
        <div class="boss-note-content">
          <div class="note-title">Reject if:</div>
          <ul>
            <li>low quality to the point it doesn't do what it says it does (shipwrights messed up - return to them)</li>
            <li>Looks like ai, but is undeclared (check declaration on the ft project page)</li>
            <li>Looks like over 30% ai - even if it is declared</li>
            <li>Looks like it isn't shipped (shipwrights messed up)</li>
            <li>last project edit was before the event launch</li>
            <li>project was worked on before event, and not marked as Project Update: in description (return to shipwrights)</li>
          </ul>
        </div>
      </section>

      <!-- Action Buttons Section -->
      <section class="review-card actions-card">
        <div class="checklist-warning">
          <div class="warning-title">Checklist (do this if u don't wanna Alex to get mad..)</div>
          <div class="warning-items">
            <div>• Check the Demo link (cuz u didn't..)</div>
            <div>• Check the Repo link (cuz u didn't..)</div>
          </div>
        </div>

        <div class="action-buttons-grid">
          <button class="action-btn btn-secondary" disabled>
            Cap Devlogs to 600 min
          </button>
          <button class="action-btn btn-approve-all" disabled>
            Approve All Devlogs
          </button>
          <button class="action-btn btn-reject-all" disabled>
            Reject All Devlogs
          </button>
          <button class="action-btn btn-return" disabled>
            Return to Ship Certs
          </button>
          <button class="action-btn btn-complete" disabled>
            Complete Review
          </button>
        </div>
      </section>
    </div>

    <!-- Right Column -->
    <div class="review-detail-right" data-review-sidebar-target="sidebar">
      <!-- Details Card -->
      <section class="review-card details-card">
        <div class="details-list">
          <div class="detail-item">
            <span class="detail-key">Project:</span>
            <span class="detail-value">
              <%= link_to @review.project.title, admin_project_path(@review.project), class: "link-primary" %>
            </span>
          </div>

          <div class="detail-item">
            <span class="detail-key">Submitter:</span>
            <span class="detail-value" style="display: flex; align-items: center; gap: var(--space-xs); flex-wrap: wrap;">
              <span><%= @review.user.display_name || @review.user.email || "Unknown User" %></span>
              <span class="fraud-links" style="display: inline-flex; gap: var(--space-xxs);">
                <a href="#" class="fraud-link" target="_blank">Billy</a>
                <a href="#" class="fraud-link" target="_blank">Joe</a>
              </span>
            </span>
          </div>

          <div class="detail-item">
            <span class="detail-key">Type:</span>
            <span class="detail-value">
              <% if @review.project.project_categories.present? %>
                <%= @review.project.project_categories.join(", ") %>
              <% else %>
                unknown
              <% end %>
            </span>
          </div>

          <div class="detail-item">
            <span class="detail-key">AI Declaration:</span>
            <span class="detail-value ai-declaration">
              <% if @review.project.ai_declaration.present? %>
                <%= @review.project.ai_declaration %>
              <% else %>
                <em>Not declared</em>
              <% end %>
            </span>
          </div>

          <div class="detail-item" style="display: grid; grid-template-columns: auto 1fr; column-gap: var(--space-m);">
            <span class="detail-key">Ship Certified:</span>
            <span class="detail-value">
              <%= @review.ship_cert_id ? "Yes" : "N/A (Reship)" %>
            </span>
            <span class="detail-key">Ship Cert:</span>
            <span class="detail-value">
              <% if @review.ship_cert_id %>
                #<%= @review.ship_cert_id %>
              <% else %>
                N/A
              <% end %>
            </span>
          </div>

          <% if @review.reviewer %>
            <div class="detail-item">
              <span class="detail-key">YSWS Reviewer:</span>
              <span class="detail-value">
                <%= link_to (@review.reviewer.display_name || @review.reviewer.email || "Unknown"), admin_user_path(@review.reviewer), class: "link-primary" %>
              </span>
            </div>
          <% end %>

          <% if @review.summary_justification.present? %>
            <div class="detail-item">
              <span class="detail-key">Return Reason:</span>
              <span class="detail-value return-reason">
                <%= @review.summary_justification %>
              </span>
            </div>
          <% end %>
        </div>

        <div class="detail-links">
          <% if @review.project.repo_url.present? %>
            <a href="<%= @review.project.repo_url %>" class="detail-link-btn" target="_blank">Repo</a>
          <% else %>
            <span class="detail-link-btn disabled" title="No repo URL available">Repo</span>
          <% end %>
          <% if @review.project.demo_url.present? %>
            <a href="<%= @review.project.demo_url %>" class="detail-link-btn" target="_blank">Demo</a>
          <% else %>
            <span class="detail-link-btn disabled" title="No demo URL available">Demo</span>
          <% end %>
          <% if @review.project.readme_url.present? %>
            <a href="<%= @review.project.readme_url %>" class="detail-link-btn" target="_blank">Readme</a>
          <% else %>
            <span class="detail-link-btn disabled" title="No readme URL available">Readme</span>
          <% end %>
        </div>
      </section>

      <!-- Description Card -->
      <section class="review-card description-card">
        <h3>Description</h3>
        <div class="description-content">
          <% if @review.project.description.present? %>
            <pre><%= @review.project.description %></pre>
          <% else %>
            <pre class="placeholder-text">No description provided</pre>
          <% end %>
        </div>
      </section>
    </div>
  </div>

  <!-- Devlogs Section (Full Width) -->
  <section class="review-card devlogs-card">
    <div class="devlogs-header">
      <h3>Devlogs (<%= @review.devlog_reviews.count %>)</h3>
    </div>

    <% if @review.devlog_reviews.any? %>
      <div class="devlogs-list">
        <% @review.devlog_reviews.each_with_index do |devlog_review, index| %>
          <div class="devlog-item" <%= 'data-review-sidebar-target="trigger"'.html_safe if index == 0 %>>
            <div class="devlog-main">
              <div class="devlog-header-row">
                <span class="devlog-id">Devlog #<%= devlog_review.post_devlog.id %></span>
                <% if devlog_review.approved? %>
                  <span class="devlog-status status-approved">Approved</span>
                <% elsif devlog_review.rejected? %>
                  <span class="devlog-status status-rejected">Rejected</span>
                <% end %>
              </div>

              <% if devlog_review.post_devlog.body.present? %>
                <p class="devlog-desc"><%= devlog_review.post_devlog.body %></p>
              <% else %>
                <p class="devlog-desc empty-body-warning">body was empty, contact @AVD, this shouldn't happen</p>
              <% end %>

              <div class="devlog-media-section">
                <div class="media-label">Devlog Media (<%= devlog_review.post_devlog.attachments.size %>)</div>
                <% if devlog_review.post_devlog.attachments.any? %>
                  <div class="media-grid">
                    <% devlog_review.post_devlog.attachments.each do |attachment| %>
                      <% if attachment.video? %>
                        <a href="<%= url_for(attachment) %>" target="_blank" class="media-item video-item">
                          <video class="media-thumbnail" muted>
                            <source src="<%= url_for(attachment) %>" type="<%= attachment.content_type %>">
                          </video>
                          <div class="media-type-badge">Video</div>
                        </a>
                      <% else %>
                        <a href="<%= url_for(attachment) %>" target="_blank" class="media-item image-item">
                          <%= image_tag attachment.variant(:thumb), class: "media-thumbnail", alt: "Devlog attachment" %>
                        </a>
                      <% end %>
                    <% end %>
                  </div>
                <% else %>
                  <div class="media-placeholder">
                    <div class="placeholder-text">No media attached</div>
                  </div>
                <% end %>
              </div>

              <div class="devlog-time">
                Original Time:
                <span class="time-value"><%= devlog_review.original_minutes || 0 %> minutes</span>
                <em>(<%= ((devlog_review.original_minutes || 0) / 60.0).round(1) %> hrs)</em>
              </div>

              <div class="devlog-git-section">
                <div class="git-label">Git Activity</div>
                <div class="chart-placeholder small">
                  <div class="placeholder-text">Placeholder for Commit Chart</div>
                </div>
              </div>
            </div>

            <!-- Review Decision Panel -->
            <div class="devlog-review-panel">
              <div class="panel-title">Review Decision</div>

              <div class="panel-section">
                <div class="panel-label">Status:</div>
                <div class="status-buttons">
                  <button class="status-btn btn-approve" disabled>
                    ✓ Approve
                  </button>
                  <button class="status-btn btn-reject" disabled>
                    ✗ Reject
                  </button>
                </div>
              </div>

              <div class="panel-section">
                <div class="panel-label">Approved Minutes:</div>
                <div class="minutes-input-group">
                  <input type="number"
                         value="<%= devlog_review.approved_minutes || devlog_review.original_minutes || 0 %>"
                         class="minutes-input"
                         disabled>
                  <span class="minutes-label">minutes</span>
                </div>
                <div class="quick-adjust-buttons">
                  <button class="adjust-btn" disabled>50%</button>
                  <button class="adjust-btn" disabled>25%</button>
                  <button class="adjust-btn" disabled>-30min</button>
                  <button class="adjust-btn" disabled>-1hr</button>
                  <button class="adjust-btn" disabled>Reset</button>
                </div>
              </div>

              <div class="panel-section">
                <div class="panel-label">Internal Notes:</div>
                <textarea class="notes-textarea"
                          placeholder="notes..."
                          disabled><%= devlog_review.justification %></textarea>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-devlogs">
        <p>no devlogs found...</p>
      </div>
    <% end %>
  </section>
</main>
