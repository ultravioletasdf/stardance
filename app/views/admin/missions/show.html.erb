<% content_for :title, "Admin · #{@mission.name}" %>

<div class="app-layout app-layout--wide">
  <div class="app-layout__main app-layout__main--wide">
    <article class="admin-mission">
      <p class="admin-mission__breadcrumb">
        <%= link_to "← Missions", admin_missions_path, class: "admin-mission__breadcrumb-link" %>
      </p>

      <header class="admin-mission__page-header">
        <h1 class="admin-mission__page-title">
          <%= @mission.name %>
          <% if @mission.deleted_at? %>
            <span class="admin-mission__title-tag">Deleted</span>
          <% end %>
        </h1>
        <div class="admin-mission__actions">
          <%= link_to "Edit this mission →",
                      edit_admin_mission_path(@mission.slug),
                      class: "action-btn action-btn--small action-btn--primary" %>
        </div>
      </header>

      <section class="admin-mission__section">
        <h2 class="admin-mission__section-title">Quick facts</h2>
        <dl class="admin-mission__details">
          <dt>Slug</dt>
          <dd><code class="admin-mission__code"><%= @mission.slug %></code></dd>

          <dt>Enabled</dt>
          <dd>
            <% if @mission.enabled? %>
              <span class="admin-mission__bool admin-mission__bool--yes">Yes</span>
            <% else %>
              <span class="admin-mission__bool admin-mission__bool--no">No</span>
            <% end %>
          </dd>

          <% if @mission.deleted_at? %>
            <dt>Deleted at</dt>
            <dd><%= @mission.deleted_at.strftime("%b %-d, %Y %H:%M") %></dd>
          <% end %>

          <dt>Created at</dt>
          <dd><%= @mission.created_at.strftime("%b %-d, %Y %H:%M") %></dd>

          <dt>Updated at</dt>
          <dd><%= @mission.updated_at.strftime("%b %-d, %Y %H:%M") %></dd>
        </dl>
        <p class="admin-mission__hint">
          Mission content (description, guide, prizes, memberships, shop unlocks,
          default project copy, etc.) lives on the
          <%= link_to "edit page", edit_admin_mission_path(@mission.slug), class: "admin-mission__link" %>.
        </p>
      </section>

      <section class="admin-mission__section">
        <h2 class="admin-mission__section-title">Recent submissions</h2>
        <% if @submissions.any? %>
          <ul class="admin-mission__list">
            <% @submissions.each do |s| %>
              <li>
                <%= link_to "##{s.id} (#{s.status})", mission_submission_path(s), class: "admin-mission__link" %>
                — <%= s.ship_event&.post&.user&.display_name %>
                <span class="admin-mission__muted"><%= time_ago_in_words(s.created_at) %> ago</span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="admin-mission__empty">No submissions yet.</p>
        <% end %>
      </section>

      <section class="admin-mission__section">
        <h2 class="admin-mission__section-title">Audit log</h2>
        <table class="admin-mission__audit-log">
          <thead>
            <tr><th>When</th><th>Whodunnit</th><th>Item</th><th>Event</th></tr>
          </thead>
          <tbody>
            <% @versions.each do |v| %>
              <tr>
                <td class="admin-mission__muted"><%= v.created_at.strftime("%Y-%m-%d %H:%M") %></td>
                <td>
                  <% if v.whodunnit.present? %>
                    <%= @whodunnit_users[v.whodunnit]&.display_name || "user ##{v.whodunnit}" %>
                  <% else %>
                    <span class="admin-mission__muted">system</span>
                  <% end %>
                </td>
                <td><code class="admin-mission__code"><%= v.item_type %>##<%= v.item_id %></code></td>
                <td><%= v.event %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </section>
    </article>
  </div>
</div>
