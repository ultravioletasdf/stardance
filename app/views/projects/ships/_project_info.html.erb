<%= form_with(
      model: @project,
      url: project_path(@project, return_to: review_project_ships_path(@project)),
      method: :patch,
      id: "ship-details-form",
      local: true,
      html: { multipart: true },
      class: "ship__form",
      data: {
        controller: "project-form",
        action: "submit->project-form#onSubmit",
        "project-form-readme-locked-class-value": "ship__field--locked"
      }
    ) do |form| %>

  <% unless @project.shippable? %>
    <div class="ship__requirements" data-project-form-target="requirementsContainer">
      <p class="ship__requirements-heading">Complete these requirements before shipping:</p>
      <ul class="ship__requirements-list">
        <% @project.visual_shipping_requirements.reject { |r| r[:passed] }.each do |req| %>
          <li class="ship__requirements-item" data-req-key="<%= req[:key] %>">
            <%= req[:fail_label] || req[:label] %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Title, description, and banner are each their own kind of control
      (row, textarea, image upload) so they live as direct form children and
      pick up the form's larger inter-section gap. The URL trio below stays
      in a `.ship__group` so the row-to-row gap inside stays tight. %>
  <div class="ship__field">
    <div class="ship__field-row">
      <label class="ship__label" for="project_title">Project name</label>
      <%= render StarBorderComponent.new(seed: "ship-title") do %>
        <%= form.text_field :title,
              id: "project_title",
              class: "ship__input",
              placeholder: "Give your project a name",
              data: {
                action: "input->project-form#validateTitle blur->project-form#validateTitle",
                "project-form-target": "title"
              } %>
      <% end %>
    </div>
  </div>

  <div class="ship__field">
    <label class="ship__label" for="project_description">Project description</label>
    <%= render StarBorderComponent.new(seed: "ship-description") do %>
      <%= form.text_area :description,
            id: "project_description",
            class: "ship__input ship__input--textarea ship__input--textarea-short",
            rows: 3,
            placeholder: "Share what the project does, who's working on it, and what's next.",
            data: {
              action: "input->project-form#validateDescription blur->project-form#validateDescription",
              "project-form-target": "description"
            } %>
    <% end %>
  </div>

  <div class="ship__field">
    <label class="ship__label">Project banner</label>
    <p class="ship__hint">This must be a picture of your actual project — not AI-generated art. Show what you built! Upload a JPEG, PNG, WEBP, HEIC, or HEIF up to 10 MB.</p>
    <%= render StarImageInputComponent.new(
          name: "project[banner]",
          id: "project_banner",
          accept: Project::ACCEPTED_CONTENT_TYPES.join(","),
          direct_upload: true,
          current_url: (url_for(@project.banner) if @project.banner.attached?),
          current_alt: @project.banner.attached? ? "Current project banner" : "",
          primary_text: "Drag your banner image",
          secondary_text: "or click to choose a file"
        ) %>
  </div>

  <div class="ship__group">
    <div class="ship__field">
      <div class="ship__field-row">
        <span class="ship__label-with-info">
          <label class="ship__label" for="project_demo_url">Playable URL</label>
          <span class="ship__info" title="A live link reviewers can open to try your project." aria-hidden="true">?</span>
        </span>
        <%= render StarBorderComponent.new(seed: "ship-demo-url") do %>
          <%= form.url_field :demo_url,
                id: "project_demo_url",
                class: "ship__input",
                placeholder: "https://example.github.io/example",
                inputmode: "url",
                data: {
                  action: "input->project-form#validateUrl blur->project-form#validateUrl",
                  "project-form-target": "demoUrl"
                } %>
        <% end %>
      </div>
    </div>

    <div class="ship__field">
      <div class="ship__field-row">
        <span class="ship__label-with-info">
          <label class="ship__label" for="project_repo_url">Github URL</label>
          <span class="ship__info" title="Public repository with the source code for this project." aria-hidden="true">?</span>
        </span>
        <%= render StarBorderComponent.new(seed: "ship-repo-url") do %>
          <%= form.url_field :repo_url,
                id: "project_repo_url",
                class: "ship__input",
                placeholder: "https://github.com/hackclub/stardance",
                inputmode: "url",
                data: {
                  action: "input->project-form#onRepoInput blur->project-form#onRepoBlur",
                  "project-form-target": "repoUrl"
                } %>
        <% end %>
      </div>
    </div>

    <div class="ship__field"
         data-project-form-target="readmeContainer"
         <%= "hidden" if @project.readme_url.blank? %>>
      <div class="ship__field-row">
        <span class="ship__label-with-info">
          <label class="ship__label" for="project_readme_url">Readme URL</label>
          <span class="ship__info" title="Raw README URL from GitHub. We autofill this from the repo when possible." aria-hidden="true">?</span>
        </span>
        <%= render StarBorderComponent.new(seed: "ship-readme-url") do %>
          <%= form.url_field :readme_url,
                id: "project_readme_url",
                class: "ship__input",
                placeholder: "https://raw.githubusercontent.com/hackclub/stardance/refs/heads/main/README.md",
                inputmode: "url",
                data: {
                  action: "input->project-form#onReadmeInput input->project-form#validateUrl blur->project-form#validateUrl",
                  "project-form-target": "readmeUrl"
                } %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="ship__field">
    <label class="ship__label" for="project_ai_declaration">AI declaration</label>
    <p class="ship__hint">Describe how you used AI in this project (e.g. "Used ChatGPT for debugging", "GitHub Copilot for code completion"). AI use is OK, but it should feel like your own work! If you didn't use AI, you can state that.</p>
    <%= render StarBorderComponent.new(seed: "ship-ai-declaration") do %>
      <%= form.text_area :ai_declaration,
            id: "project_ai_declaration",
            class: "ship__input ship__input--textarea",
            rows: 3 %>
    <% end %>
  </div>

  <div class="ship__field">
    <label class="ship__checkbox">
      <input type="checkbox"
             class="ship__checkbox-input"
             aria-label="This project was started before June 1 2026, or was previously shipped to a Hack Club event.">
      <span class="ship__checkbox-text">
        This project was started <strong>before June 1 2026</strong>, or was <strong>previously shipped</strong> to a Hack Club event.
      </span>
    </label>
  </div>

  <div class="ship__actions">
    <%= link_to "← Back", new_project_ships_path(@project), class: "ship__back-link" %>
    <%= render SpecialActionButtonComponent.new(
          text: "Save and continue",
          type: :submit,
          form: "ship-details-form",
          disable_with: "Saving...",
          disabled: !@project.shippable?,
          data: { project_form_target: "submit" }
        ) %>
  </div>
<% end %>
