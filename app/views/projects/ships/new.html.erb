<% content_for :title, "Ship Project" %>

<div class="ship">
  <%= image_tag "projects/ship/background.png",
        alt: "",
        aria: { hidden: true },
        class: "ship__background" %>

  <%= image_tag "landing/header/stardance-logo.png",
        alt: "Stardance Challenge by Hack Club",
        class: "ship__logo" %>

  <div class="ship__header">
    <%= link_to "← back to Stardance", project_path(@project), class: "ship__back" %>

    <div class="ship__titles">
      <span class="ship__eyebrow">Let's ship</span>
      <h1 class="ship__project-name"><%= @project.title %></h1>
    </div>
  </div>

  <nav class="ship__stepper" aria-label="Ship progress">
    <div class="ship__stepper-line"></div>

    <% steps = [
      { number: 1, label: "Project info", image: "projects/ship/step-project-info.png" },
      { number: 2, label: "Review instructions", image: "projects/ship/step-review.png" },
      { number: 3, label: "Ship!", image: "projects/ship/step-ship.png" }
    ] %>

    <% steps.each do |s| %>
      <% active = s[:number] == @step %>
      <% completed = s[:number] < @step %>
      <% upcoming = s[:number] > @step %>
      <% step_classes = [
        "ship__stepper-step",
        ("ship__stepper-step--active" if active),
        ("ship__stepper-step--completed" if completed),
        ("ship__stepper-step--upcoming" if upcoming)
      ].compact %>

      <%= tag.div class: step_classes, aria: (active ? { current: "step" } : {}) do %>
        <span class="ship__stepper-marker">
          <%= image_tag s[:image], alt: "", aria: { hidden: true }, class: "ship__stepper-star" %>
        </span>
        <span class="ship__stepper-label"><%= s[:label] %></span>
      <% end %>
    <% end %>
  </nav>

  <p class="ship__subtitle">
    <% case @step %>
    <% when 1 %>
      Double-check your project info. Reviewers will use this to evaluate your ship!
    <% when 2 %>
      Help reviewers test your project!
    <% when 3 %>
      Tell the community what you built and what you learnt!
    <% end %>
  </p>

  <div class="ship__video">
    <%= render VimeoEmbedComponent.new(video: :what_is_a_ship) %>
  </div>

  <div class="ship__body ship__body--step-<%= @step %>">
    <% case @step %>
    <% when 1 %>
      <%= render "project_info" %>
    <% when 2 %>
      <%= render "review_instructions" %>
    <% when 3 %>
      <%= render "ship_composer" %>
    <% end %>
  </div>
</div>
