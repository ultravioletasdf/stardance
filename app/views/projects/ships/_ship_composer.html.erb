<%# Wrap the composer + page-level actions in a single controller scope so
    the "Ship and post" SpecialActionButton (rendered outside the .feed-composer
    section, at the bottom of the page) is still a descendant of the composer
    controller. That keeps `data-composer-target="submit"` resolvable and lets
    the live enable-as-you-type behavior reach the button. %>
<div data-controller="composer emoji-picker"
     data-composer-simple-mode-value="true">
  <% mission = @project.current_mission %>
  <% if mission && !@project.shipped_to_mission?(mission) %>
    <%# Rendered above the composer; its fields associate with the ship form
        via the HTML form="ship-form" attribute since they live outside it. %>
    <div class="ship__mission">
      <p class="ship__mission-heading">
        Shipping to <strong class="ship__mission-name"><%= mission.name %></strong>
      </p>
      <%= hidden_field_tag :mission_payout_path, "static_prize", form: "ship-form" %>

      <% if mission.submission_guide.present? %>
        <div class="ship__mission-guide">
          <h2 class="ship__mission-guide-title">Mission requirements</h2>
          <div class="ship__mission-guide-body">
            <%= render MarkdownContentComponent.new(markdown: mission.submission_guide, flavor: :guide) %>
          </div>
          <label class="ship__mission-ack">
            <%= check_box_tag :mission_submission_guide_acknowledged, "1", false, required: true, form: "ship-form" %>
            <span>I've read the mission requirements for <strong><%= mission.name %></strong>.</span>
          </label>
        </div>
      <% end %>
    </div>
  <% end %>

  <section class="feed-composer"
           aria-label="Ship your project"
           data-composer-target="dropZone"
           data-action="drop->composer#drop dragover->composer#dragover dragleave->composer#dragleave">

    <%= form_with(
          url: project_ships_path(@project),
          method: :post,
          id: "ship-form",
          html: { data: { composer_target: "form", action: "paste->composer#paste", turbo_frame: "_top" } },
          class: "feed-composer__form",
          local: true
        ) do |form| %>

      <div class="feed-composer__main">
        <%= image_tag current_user.avatar, alt: "", class: "feed-composer__avatar" %>

        <div class="feed-composer__field">
          <%= form.label :ship_update, "What did you make?", class: "feed-composer__label" %>
          <%= form.text_area :ship_update,
                class: "feed-composer__textarea",
                rows: 1,
                required: true,
                maxlength: Post::ShipEvent::BODY_MAX_LENGTH,
                placeholder: "What did you make? What was challenging? What are you proud of?",
                aria: { label: "Ship update" },
                data: { composer_target: "textarea",
                        emoji_picker_target: "textarea",
                        action: "focus->composer#showInfo input->composer#autogrow input->composer#refreshSubmit blur->composer#collapseIfEmpty" } %>
        </div>
      </div>

      <div class="feed-composer__toolbar">
        <div class="feed-composer__tools">
          <div class="feed-composer__emoji-wrap">
            <button type="button"
                    class="feed-composer__tool-btn"
                    aria-label="Add emoji"
                    data-emoji-picker-target="trigger"
                    data-action="emoji-picker#toggle">
              <%= inline_svg_tag "icons/emoji.svg", class: "feed-composer__tool-icon" %>
            </button>
            <div class="feed-composer__emoji-popover"
                 data-emoji-picker-target="popover"
                 hidden></div>
          </div>
        </div>
      </div>
    <% end %>
  </section>

  <div class="ship__actions">
    <%= link_to "← Back", new_project_ships_path(@project), class: "ship__back-link" %>
    <%= render SpecialActionButtonComponent.new(
          text: "Ship and post",
          type: :submit,
          form: "ship-form",
          disable_with: "Shipping...",
          disabled: !@project.shippable?,
          data: { composer_target: "submit" }
        ) %>
  </div>
</div>
