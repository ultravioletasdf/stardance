<%
  steps = []

  # In editing mode the Edit-project pill becomes "Discard changes" (same
  # class), so the "click edit" step doesn't apply — start straight at the
  # in-form tour.
  unless params[:editing].present?
    steps << {
      selector: ".project-show__pill--outline",
      text: "yay!! now go here to edit your project and add your hackatime project",
      padding: 8,
      radius: 999,
      arrowPosition: "bottom",
      clickToAdvance: true
    }
  end

  steps << {
    selector: ".project-show--editing",
    text: "Here's where you can edit your project's info.",
    padding: 12,
    radius: 12,
    maxHeight: 400,
    waitForTarget: true
  }

  steps << {
    selector: ".project-show__field--hackatime",
    text: "To get started with logging your time and devlogging, attach your Hackatime project.",
    padding: 12,
    radius: 12,
    waitForTarget: true
  }
%>

<div class="welcome-tour"
     data-controller="welcome-tour"
     data-welcome-tour-steps-value="<%= steps.to_json %>"
     data-welcome-tour-lock-scroll-value="false"
     role="dialog"
     aria-modal="true"
     aria-label="Hackatime onboarding">
  <div class="welcome-tour__overlay" aria-hidden="true"></div>
  <div class="welcome-tour__spotlight"
       data-welcome-tour-target="spotlight"
       aria-hidden="true"></div>

  <div class="welcome-tour__tooltip" data-welcome-tour-target="tooltip">
    <%= inline_svg_tag "icons/tour-arrow.svg",
                       class: "welcome-tour__arrow",
                       aria: { hidden: true },
                       focusable: false %>

    <p class="welcome-tour__text" data-welcome-tour-target="text"></p>

    <div class="welcome-tour__actions">
      <button type="button"
              class="welcome-tour__back"
              data-welcome-tour-target="back"
              data-action="click->welcome-tour#back"
              hidden>
        Back
      </button>
      <button type="button"
              class="welcome-tour__next"
              data-welcome-tour-target="next"
              data-action="click->welcome-tour#next">
      </button>
    </div>

    <span class="welcome-tour__counter"
          data-welcome-tour-target="counter"
          aria-hidden="true"></span>
  </div>
</div>
