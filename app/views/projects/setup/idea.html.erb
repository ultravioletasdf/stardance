<% content_for :title, "Your first project" %>
<main class="onboarding-screen onboarding-screen--project-idea project-setup-screen"
      data-controller="onboarding-transition">
  <%= render Projects::Setup::ProgressBarComponent.new(action: :idea) %>

  <div class="onboarding-screen__content">
    <p class="onboarding-screen__eyebrow">Let's make your first project ✦</p>
    <h1 class="onboarding-screen__title">Do you have an idea<br>of what you want to make?</h1>

    <%= form_with url: projects_setup_submit_idea_path, method: :post,
                   class: "project-setup-idea__form" do %>
      <div class="project-setup-idea__cards">
        <%= render Onboarding::ChoiceCardComponent.new(name: "idea", value: "yes", variant: :pair) do %>
          Yes! I know what I want to build.
        <% end %>
        <%= render Onboarding::ChoiceCardComponent.new(name: "idea", value: "no", variant: :pair) do %>
          Not yet — help me find one.
        <% end %>
      </div>
    <% end %>
  </div>
</main>
