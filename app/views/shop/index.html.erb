<% content_for :title, "Shop" %>
<% content_for :og_title, "Stardance Shop" %>
<% content_for :og_description, "Spend your Stardust on stickers, hardware, and other prizes. Earn Stardust by building projects and voting!" %>
<% content_for :og_image, og_image_url('shop', format: :png) %>

<div class="shop" data-controller="shop" data-shop-user-region-value="<%= @user_region %>">
  <%= render HeadingComponent.new(title: "Shop", tone: :blue, size: :full) %>

  <div class="shop-goals" data-controller="shop-goals" data-shop-goals-balance-value="<%= @user_balance %>" data-shop-goals-stardust-icon-url-value="<%= image_path('icons/stardust.png') %>">
    <div class="shop-goals__container" data-shop-goals-target="container" style="display: none;">
      <h3 class="shop-goals__title"><%= inline_svg_tag "icons/star_fill.svg" %> My Goal Items</h3>
      <div class="shop-goals__items" data-shop-goals-target="items"></div>
    </div>
    <script>
      try {
        var w = JSON.parse(localStorage.getItem("shop_wishlist"));
        if (w && Object.keys(w).length) document.currentScript.previousElementSibling.style.display = "block";
      } catch (e) {}
    </script>
  </div>

  <% if @shop_open %>
    <% if current_user&.admin? %>
      <div class="admin-banner">
        <div class="admin-banner__content">
          <span class="admin-banner__count"><%= @shop_items.count %> items</span>
          <%= link_to "Edit items →", admin_manage_shop_path, class: "admin-banner__link" %>
        </div>
      </div>
    <% end %>

    <% unless current_user %>
      <div class="shop__signup-cta">
        <div class="shop__signup-cta-content">
          <h3><%= stardust_icon %> Want to order something?</h3>
          <p>Join <%= link_to "Hack Club Stardance", "/" %> to start earning Stardust by building personal projects!</p>
        </div>
        <div class="shop__signup-cta-buttons">
          <%= link_to "Get building!", root_path, class: "action-btn action-btn--large action-btn--primary shop__signup-cta-btn" %>
          <%= form_tag "/auth/hack_club", method: :post, data: { turbo: false }, class: "shop__signin-form" do %>
            <button type="submit" class="shop__signin-link">Already a member? Sign in</button>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="shop__buttons">
      <% if current_user %>
        <%= render ActionButtonComponent.new(
          text: "View My Orders",
          href: "/shop/my_orders",
          size: :small,
          variant: :secondary
        ) %>
      <% end %>
      <%= render DropdownComponent.new(
        label: "Region",
        options: @region_options,
        selected_option: Shop::Regionalizable::REGIONS.dig(@user_region, :name),
        color: :brown,
        action: "change->shop#filter"
      ) %>
    </div>
    <% if @featured_item && current_user %>
      <%= render partial: "shop/banner", locals: { featured_item: @featured_item, user_region: @user_region } %>
    <% end %>
    <%= render partial: "shop/recently_added", locals: { recently_added_items: @recently_added_items, user_region: @user_region, user_balance: @user_balance, logged_in: current_user.present? } %>
    <div class="shop__nav">
      <div class="shop__searchbar">
        <%= form_with url: shop_path, method: :get, local: true do |f| %>
          <%= render InputComponent.new(
            label: nil,
            icon: "icons/search.svg",
            placeholder: "Search item",
            form: f,
            attribute: :q,
            color: :yellow,
            input_html: {
              value: params[:q],
              data: { action: "input->shop#search" }
            }
          ) %>
        <% end %>
      </div>
      <div class="shop__filters">
        <%= render DropdownComponent.new(
          label: "Category",
          options: ["All", "Grants", "HQ", "Digital", "Locally Fulfilled", "Made by Hack Clubbers"],
          selected_option: "All",
          color: :blue,
          action: "change->shop#filter"
        ) %>
        <%= render DropdownComponent.new(
          label: "Price Range",
          options: [
            { label: "None", value: "none" },
            { label: "0 - 100", value: "0-100" },
            { label: "100 - 500", value: "100-500" },
            { label: "500 - 1000", value: "500-1000" },
            { label: "> 1000", value: "1000+" }
          ],
          selected_option: "None",
          color: :pink,
          action: "change->shop#filter"
        ) %>
        <%= render DropdownComponent.new(
          label: "Sort by",
          options: ["Prices", "Alphabetical"],
          selected_option: "Prices",
          color: :green,
          action: "change->shop#filter"
        ) %>
        <%= render DropdownComponent.new(
          label: "Access",
          options: ["All", "Available", "Locked"],
          selected_option: "All",
          color: :red,
          action: "change->shop#filter"
        ) %>
        <button id="sort-btn">
          <span>
            <%= inline_svg_tag "icons/sort.svg", title: "Sort Icon" %>
          </span>
          <%= inline_svg_tag "icons/sort-btn-icon.svg", title: "Sort Arrow" %>
        </button>
      </div>
    </div>
    <%= turbo_frame_tag "shop_items" do %>
      <div class="shop__items">
        <% @shop_items.each do |item| %>
          <% if item.image.present? && item.enabled_in_region?(@user_region) %>
            <% sale_price = item.price_for_region(@user_region) %>
            <% item_achievement_infos = item.required_achievement_objects %>
            <% item_achievement_locked = item.achievement_locked_for?(current_user) %>
            <%= render ShopItemCardComponent.new(
              item_id: item.id,
              name: item.name,
              description: item.description,
              hours: item.fixed_estimate(sale_price).to_i,
              price: item.ticket_cost,
              image_url: item.image.variant(:carousel_lg),
              item_type: item.type,
              balance: @user_balance,
              enabled_regions: item.enabled_region_codes,
              regional_price: sale_price,
              logged_in: current_user.present?,
              remaining_stock: item.remaining_stock,
              limited: item.limited?,
              on_sale: item.on_sale?,
              sale_percentage: item.sale_percentage,
              original_price: item.base_price_for_region(@user_region),
              purchase_count: item.display_purchase_count,
              is_new: item.new_item?,
              enabled_until: item.enabled_until,
              locked_by_achievement: item_achievement_locked,
              required_achievement_names: item_achievement_infos.map(&:name),
              required_achievement_hints: item_achievement_infos.map(&:description)
            ) %>
          <% end %>
        <% end %>
        <div class="shop__empty" style="display: none;" data-shop-target="empty">
          <p>No items match your filters.</p>
        </div>
      </div>
    <% end %>
  <% else %>
    <h2>The shop is not opened yet!</h2>
  <% end %>
</div>

<% if current_user && Flipper.enabled?(:shop_suggestion_box, current_user) && !current_user.has_dismissed?("shop_suggestion_box") %>
  <div class="shop-suggestion-box">
    <button type="button" class="shop-suggestion-box__trigger" onclick="document.getElementById('shop-suggestion-modal').showModal()">
      <%= image_tag "Rummage.avif", alt: "Suggestion Box", class: "shop-suggestion-box__image" %>
    </button>
  </div>

  <dialog id="shop-suggestion-modal" class="shop-suggestion-modal">
      <button type="button" class="shop-suggestion-modal__close" onclick="document.getElementById('shop-suggestion-modal').close()" aria-label="Close">
        X
      </button>

      <h2 class="shop-suggestion-modal__title">The Suggestion Box</h2>
      <p class="shop-suggestion-modal__description">Have an idea for something we should add to the shop? Let us know!</p>

      <%= form_with model: ShopSuggestion.new, url: shop_suggestions_path, local: true, class: "shop-suggestion-modal__form" do |f| %>
        <div class="shop-suggestion-modal__field">
          <%= f.label :item, "What can we add?" %>
          <%= f.text_area :item,
                          placeholder: "A super cool HeidixOrpheusxForever plushie!",
                          rows: 1,
                          required: true,
                          minlength: 10,
                          maxlength: 1000 %>
        </div>

        <div class="shop-suggestion-modal__field">
          <%= f.label :explanation, "How would this help you as a hacker?" %>
          <%= f.text_area :explanation,
                          placeholder: "The entire world needs this...",
                          rows: 4,
                          required: true,
                          minlength: 10,
                          maxlength: 10000 %>
        </div>

        <div class="shop-suggestion-modal__field">
          <%= f.label :link, "Link to the item (if applicable)" %>
          <%= f.url_field :link,
                          placeholder: "https://hackclub.com/iwantmoreplushies",
                          maxlength: 2000 %>
        </div>

        <%= f.submit "Submit Suggestion", class: "action-btn action-btn--large action-btn--primary" %>
      <% end %>
  </dialog>
<% end %>
