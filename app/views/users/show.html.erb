<% content_for :title, @user.display_name %>
<% content_for :og_title, "#{@user.display_name} on Stardance" %>
<% content_for :og_description, "#{@stats[:projects_count]} projects · #{@stats[:ships_count]} ships · #{@stats[:devlogs_count]} devlogs" %>
<% content_for :og_image, user_og_image_url(@user, format: :png) %>

<% if @user.preference.search_engine_indexing_off? %>
  <% content_for :head do %>
    <meta name="robots" content="noindex, nofollow">
  <% end %>
<% end %>

<% own_profile = current_user&.id == @user.id %>
<% banner_url = @user.banner.attached? ? url_for(@user.banner) : image_path("profile/default-banner.png") %>

<div class="app-layout">
  <div class="app-layout__main">
    <%= turbo_frame_tag "profile_card" do %>
    <%= form_with model: @user, url: user_path(@user), method: :patch, multipart: true,
                  class: "profile",
                  data: {
                    controller: "profile-edit",
                    "profile-edit-editing-class": "profile--editing",
                    "profile-edit-default-banner-value": image_path("profile/default-banner.png")
                  } do |f| %>

  <header class="profile__header">
    <div class="profile__banner">
      <%= image_tag banner_url, alt: "", class: "profile__banner-image",
                    data: { "profile-edit-target": "banner" } %>
      <%= link_to back_path,
                  class: "profile__back",
                  "aria-label": "Back",
                  data: { turbo_frame: "_top" } do %>
        <svg class="profile__back-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 6l-6 6 6 6" />
        </svg>
      <% end %>

      <% if own_profile %>
        <label class="profile__banner-upload" data-profile-edit-target="bannerLabel">
          <span class="profile__banner-upload-text">Change banner</span>
          <%= f.file_field :banner, accept: "image/*",
                           class: "profile__banner-input",
                           data: { action: "change->profile-edit#previewBanner",
                                   "profile-edit-target": "bannerInput" } %>
        </label>
      <% end %>
    </div>

    <div class="profile__card">
      <div class="profile__top-row">
        <div class="profile__identity">
          <div class="profile__avatar-wrap">
            <%= image_tag(@user.avatar, alt: @user.display_name, class: "profile__avatar") %>
          </div>

          <div class="profile__identity-text">
            <h1 class="profile__handle">@<%= @user.display_name %></h1>
            <% if own_profile %>
              <div class="profile__handle-edit">
                <span class="profile__handle-edit-at" aria-hidden="true">@</span>
                <%= f.text_field :display_name,
                                 class: "profile__handle-input",
                                 maxlength: 60,
                                 required: true,
                                 aria: { label: "Display name" } %>
              </div>
            <% end %>
            <p class="profile__joined">Joined <%= @user.created_at.to_date.strftime("%-d %b %Y").downcase %></p>
          </div>
        </div>

        <ul class="profile__stats" aria-label="User stats">
          <li class="profile__stat"><span class="profile__stat-num"><%= @stats[:devlogs_count] %></span><span class="profile__stat-label">Devlogs</span></li>
          <li class="profile__stat"><span class="profile__stat-num"><%= @stats[:projects_count] %></span><span class="profile__stat-label">Projects</span></li>
          <li class="profile__stat"><span class="profile__stat-num"><%= @stats[:ships_count] %></span><span class="profile__stat-label">Ships</span></li>
          <li class="profile__stat"><span class="profile__stat-num"><%= @stats[:votes_count] %></span><span class="profile__stat-label">Votes</span></li>
        </ul>
      </div>

      <div class="profile__bio" data-profile-edit-target="bioView">
        <% if @user.bio.present? %>
          <%= render_bio(@user.bio) %>
        <% elsif own_profile %>
          <span class="profile__bio-empty">Add a bio to tell folks who you are.</span>
        <% end %>
      </div>

      <% if own_profile %>
        <div class="profile__bio-editor"
             data-profile-edit-target="bioEdit"
             data-controller="bio-editor"
             data-bio-editor-users-url-value="<%= search_users_path(format: :json) %>"
             data-bio-editor-projects-url-value="<%= search_projects_path(format: :json) %>"
             data-bio-editor-initial-value="<%= @user.bio.to_s %>"
             hidden>
          <div class="profile__bio-input"
               contenteditable="true"
               role="textbox"
               aria-label="Edit bio. Type @ to mention a user, $ to link a project."
               data-bio-editor-target="editor"
               data-action="input->bio-editor#onInput keydown->bio-editor#onKeydown blur->bio-editor#onBlur"></div>
          <%= f.hidden_field :bio, data: { "bio-editor-target": "hidden" } %>
          <div class="profile__bio-suggest"
               data-bio-editor-target="suggest"
               role="listbox"
               hidden></div>
          <p class="profile__bio-hint">Type <kbd>@</kbd> to mention a user, <kbd>$</kbd> to link a project.</p>
        </div>
      <% end %>

      <div class="profile__footer">
        <p class="profile__follow-counts">
          <%= button_tag type: "button",
                         class: "profile__follow-count",
                         data: { action: "click->profile-modal#open",
                                 "profile-modal-url-param": following_user_path(@user),
                                 "profile-modal-title-param": "Following" } do %>
            <strong><%= @following_count %></strong> following
          <% end %>
          <%= button_tag type: "button",
                         class: "profile__follow-count",
                         data: { action: "click->profile-modal#open",
                                 "profile-modal-url-param": followers_user_path(@user),
                                 "profile-modal-title-param": "Followers" } do %>
            <strong><%= @follower_count %></strong> followers
          <% end %>
        </p>

        <div class="profile__actions">
          <% if own_profile %>
            <button type="button"
                    class="profile__action-btn"
                    data-action="click->profile-edit#cancel"
                    data-profile-edit-target="cancelBtn"
                    hidden>Cancel</button>
            <button type="button"
                    class="profile__action-btn profile__action-btn--primary"
                    data-action="click->profile-edit#enter"
                    data-profile-edit-target="editBtn">Edit profile</button>
            <button type="submit"
                    class="profile__action-btn profile__action-btn--primary"
                    data-profile-edit-target="saveBtn"
                    hidden>Save</button>
          <% elsif current_user %>
            <%# link_to + data-turbo-method instead of button_to: button_to renders %>
            <%# its own <form>, which HTML5 parsing strips when nested inside the %>
            <%# profile-edit form_with — clicking it would otherwise submit the %>
            <%# wrong form. %>
            <%= link_to user_follow_path(@user),
                        class: [ "profile__action-btn", "profile__action-btn--primary", ("profile__action-btn--following" if @viewer_follows) ].compact.join(" "),
                        data: { turbo_method: (@viewer_follows ? :delete : :post), turbo_frame: "_top" } do %>
              <span class="profile__follow-label-default"><%= @viewer_follows ? "Following" : "Follow" %></span>
              <% if @viewer_follows %>
                <span class="profile__follow-label-hover">Unfollow</span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </header>
<% end %>
    <% end %>

<%= turbo_frame_tag "profile_tabs", target: "_top" do %>
<nav class="profile-tabs" role="tablist" aria-label="Profile sections">
  <% [
    [ "feed",     "Feed",                         user_path(@user) ],
    [ "projects", "Projects (#{@stats[:projects_count]})", projects_user_path(@user) ]
  ].each do |key, label, path| %>
    <% tab_active = (@active_tab == key) %>
    <%= link_to label,
                path,
                role: "tab",
                "aria-selected": tab_active,
                class: [ "profile-tabs__tab", ("profile-tabs__tab--active" if tab_active) ].compact.join(" "),
                data: { turbo_frame: "profile_tabs", turbo_action: "advance" } %>
  <% end %>
</nav>

<section class="profile-tab-content" role="tabpanel" aria-label="<%= @active_tab.titleize %>">
  <% case @active_tab %>
  <% when "feed" %>
    <% if @activity.any? %>
      <% @activity.each do |post| %>
        <% if post.postable_type == "Post::ShipEvent" %>
          <%= render "projects/ship_card", post: post, project: post.project %>
        <% else %>
          <%= render PostComponent.new(post: post, current_user: current_user, theme: :profile_dark) %>
        <% end %>
      <% end %>
    <% else %>
      <p class="profile-tab-content__empty">No activity yet.</p>
    <% end %>
  <% when "projects" %>
    <% if @projects.any? %>
      <ul class="project-list">
        <% @projects.each do |project| %>
          <li class="project-list__item">
            <%= link_to project_path(project), class: "profile-project-card" do %>
              <div class="profile-project-card__banner">
                <% if project.banner.attached? %>
                  <%= image_tag project.banner, alt: "", class: "profile-project-card__banner-img" %>
                <% end %>
              </div>

              <div class="profile-project-card__body">
                <div class="profile-project-card__header">
                  <h3 class="profile-project-card__title"><%= project.title %></h3>
                  <ul class="profile-project-card__meta">
                    <li class="profile-project-card__meta-item">
                      <%= inline_svg_tag "icons/devlogs.svg", class: "profile-project-card__meta-icon" %>
                      <span><%= pluralize(project.devlogs_count, "devlog") %></span>
                    </li>
                    <li class="profile-project-card__meta-item profile-project-card__meta-item--time">
                      <%= inline_svg_tag "icons/time.svg", class: "profile-project-card__meta-icon profile-project-card__meta-icon--time" %>
                      <span><%= (project.duration_seconds / 3600.0).round %>h</span>
                    </li>
                  </ul>
                </div>

                <% authors = project.users.to_a %>
                <% if authors.any? %>
                  <p class="profile-project-card__authors">
                    By
                    <% authors.each_with_index do |author, idx| %>
                      <%= "and " if idx > 0 && idx == authors.length - 1 %><span class="profile-project-card__author">@<%= author.display_name %></span><%= "," if idx < authors.length - 2 && authors.length > 2 %>
                    <% end %>
                  </p>
                <% end %>

                <% if project.description.present? %>
                  <p class="profile-project-card__description"><%= project.description %></p>
                <% end %>

                <% mission = project.current_mission %>
                <div class="profile-project-card__footer">
                  <p class="profile-project-card__updated">Last updated <%= time_ago_in_words(project.updated_at) %> ago</p>
                  <% if mission %>
                    <span class="profile-project-card__mission-badge" title="Active mission: <%= mission.name %>">
                      <% if mission.icon.attached? %>
                        <%= image_tag mission.icon, class: "profile-project-card__mission-badge-icon", alt: "" %>
                      <% end %>
                      <span class="profile-project-card__mission-badge-name"><%= mission.name %></span>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </li>
        <% end %>

        <% if own_profile %>
          <li class="project-list__item">
            <%= link_to new_project_path, class: "profile-project-card profile-project-card--new" do %>
              <span>Create a new Project</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <% if own_profile %>
        <%= link_to new_project_path, class: "empty-project-banner", aria: { label: "Create your first project" } do %>
          <p class="empty-project-banner__headline">
            <span class="empty-project-banner__word">Create your </span><span class="empty-project-banner__word empty-project-banner__word--emph">first project</span><span class="empty-project-banner__word"> +</span>
          </p>
          <p class="empty-project-banner__subhead">to begin posting</p>
          <span class="empty-project-banner__reward">
            <span class="empty-project-banner__reward-label">EARNS 10 STARDUST</span>
            <%= image_tag "icons/stardust.png", alt: "", class: "empty-project-banner__reward-icon" %>
          </span>
        <% end %>
      <% else %>
        <p class="profile-tab-content__empty">No projects yet.</p>
      <% end %>
    <% end %>
  <% end %>
</section>
<% end %>
  </div>

  <%= render DiscoverRailComponent.new %>
</div>

<dialog id="followers-modal"
        class="followers-modal"
        data-controller="profile-modal"
        data-profile-modal-target="dialog">
  <header class="followers-modal__header">
    <h2 class="followers-modal__title" data-profile-modal-target="title">Followers</h2>
    <button type="button" class="followers-modal__close" data-action="click->profile-modal#close" aria-label="Close">×</button>
  </header>
  <div class="followers-modal__body" data-profile-modal-target="body">
    <p class="followers-modal__loading">Loading…</p>
  </div>
</dialog>
