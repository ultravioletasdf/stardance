<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? "#{strip_tags(yield(:title))} - Stardance" : "Sign up - Stardance" %></title>
    <%= favicon_link_tag "favicon.png", type: "image/png" %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex">
    <meta name="turbo-cache-control" content="no-cache">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= render "shared/fullstory" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body class="onboarding-body" data-turbo="true">
    <div id="onboarding-ambient" class="onboarding-ambient" aria-hidden="true" data-turbo-permanent>
      <video class="onboarding-ambient__video" autoplay muted loop playsinline preload="auto">
        <source src="<%= asset_path("stardance-bg.webm") %>" type="video/webm">
      </video>
      <div class="onboarding-ambient__overlay"></div>
    </div>
    <div id="flash-region"><%= render "shared/flash" %></div>
    <%= yield %>
  </body>
</html>
