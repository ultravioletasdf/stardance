<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? "#{strip_tags(yield(:title))} - Stardance" : "Stardance - Hack Club" %></title>
    <%= favicon_link_tag 'favicon.png', type: 'image/png' %>
    <%= favicon_link_tag '/apple-touch-icon.png', rel: 'apple-touch-icon', sizes: '180x180', type: 'image/png' %>
    <meta name="apple-mobile-web-app-title" content="Stardance">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta property="og:type" content="website">
    <meta name="twitter:site" content="@hackclub">
    <meta name="twitter:creator" content="@hackclub">
    <meta property="og:locale" content="en_US">
    <meta property="og:site_name" content="Stardance - Hack Club">

    <% og_title = content_for?(:og_title) ? yield(:og_title) : (content_for?(:title) ? "#{yield(:title)} - Stardance" : "Stardance - Hack Club") %>
    <% og_description = content_for?(:og_description) ? yield(:og_description) : "The largest STEM event of the summer: make anything you want and earn free prizes." %>
    <% og_image = content_for?(:og_image) ? yield(:og_image) : image_url("landing/space/og-default.png") %>
    <% og_url = content_for?(:og_url) ? yield(:og_url) : request.original_url %>
    <% twitter_card = content_for?(:twitter_card) ? yield(:twitter_card) : "summary" %>

    <meta name="description" content="<%= og_description %>">
    <meta property="og:title" content="<%= og_title %>">
    <meta property="og:description" content="<%= og_description %>">
    <meta property="og:url" content="<%= og_url %>">
    <meta property="og:image" content="<%= og_image %>">
    <meta name="twitter:card" content="<%= twitter_card %>">
    <meta name="twitter:title" content="<%= og_title %>">
    <meta name="twitter:description" content="<%= og_description %>">
    <meta name="twitter:image" content="<%= og_image %>">
    <% if content_for?(:og_author) %><meta name="author" content="<%= yield(:og_author) %>"><% end %>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="turbo-prefetch" content="false">
    <% if @active_nav_slug.present? %><meta name="active-nav-slug" content="<%= @active_nav_slug %>"><% end %>

    <%= preload_link_tag image_path("landing/space/moon.png"), as: "image", fetchpriority: "high" if controller_name == "landing" %>
    <%= preload_link_tag asset_path("Roboto.ttf"), as: "font", type: "font/ttf", crossorigin: true %>

    <%= yield :head %>
    <%= render "shared/fullstory" %>

    <%= yield :stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <% if Rails.env.production? %>
      <script async src="https://plausible.io/js/pa-8UNXJ41xxW9knU4pKr95g.js"></script>
      <script>
        window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
        plausible.init()
      </script>
      <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18182651878"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'AW-18182651878');
      </script>
    <% end %>
    <%# Testing our second instance of plausible — beta only %>
    <% if in_beta? %>
      <script defer data-domain="stardance.hackclub.com" src="https://plausible.hackclub.com/js/script.js"></script>
    <% end %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <%= Sentry.get_trace_propagation_meta.html_safe %> <%# erb_lint:disable ErbSafety %>
  </head>

  <body class="<%= !@hide_sidebar ? 'signed-in' : '' %> <%= @body_class %> <%= 'streamer-mode' if session[:streamer_mode] %>">
    <% if @show_boot_splash %>
      <div class="app-loading" aria-hidden="true">
        <div class="app-loading__inner">
          <%= image_tag "landing/header/stardance-logo.png", alt: "", class: "app-loading__logo" %>
          <span class="app-loading__spinner"></span>
        </div>
      </div>
    <% end %>
    <div class="top-banners">
      <% if in_beta? %>
        <div class="top-banner top-banner--beta">
          <strong>Beta</strong> &mdash; This is a testing environment. Your data may be reset at any time.
        </div>
      <% end %>
      <% if impersonating? %>
        <div class="top-banner top-banner--impersonation">
          <div class="top-banner__content">
            <div class="top-banner__text">
              <strong>Impersonating:</strong> <%= current_user.display_name %>
              <span class="top-banner__detail">(as <%= real_user.display_name %>)</span>
            </div>
            <%= button_to "Stop Impersonating",
                          admin_impersonation_path,
                          method: :delete,
                          class: "top-banner__action",
                          form: { style: "margin: 0;" } %>
          </div>
        </div>
      <% end %>
    </div>
    <% unless @hide_sidebar || current_user&.banned? %>
      <%= render SidebarComponent.new(user: current_user, active_slug_override: @active_nav_slug) %>
      <% if current_user.present? %>
        <%= render CommandPaletteComponent.new(current_user: current_user) %>
      <% end %>
    <% end %>
    <div id="flash-region"><%= render "shared/flash" %></div>
    <%= render Onboarding::GuestBannerComponent.new unless @hide_sidebar %>
    <%= yield %>
    <%= render "shared/slack_doodle" %>
    <%= render "shared/idv_verify_modal" %>
    <% unless @hide_footer %>
      <footer class="dev-footer">
        <p>
          Build <%= link_to Rails.application.config.git_version, Rails.application.config.commit_link %>
          from <%= time_ago_in_words(Rails.application.config.server_start_time) %> ago.
          (DB: <%= pluralize(QueryCount::Counter.counter, "query") %>, <%= QueryCount::Counter.counter_cache %> cached)
          (CACHE: <%= cache_stats[:hits] %> hits, <%= cache_stats[:misses] %> misses)
          (<%= requests_per_second %>)
          (Active: <%= active_users_stats %>)
        </p>
      </footer>
    <% end %>
  </body>
</html>
