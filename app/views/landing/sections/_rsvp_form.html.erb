<%
  wrapper_class = local_assigns[:wrapper_class]
  placeholder   = local_assigns[:placeholder] || "jebediah@hackclub.com"
  leading       = local_assigns[:leading]
  trailing      = local_assigns[:trailing]
  signup_mode   = local_assigns.fetch(:new_onboarding) { Flipper.enabled?(:new_onboarding) }
  form_url      = signup_mode ? onboarding_start_path : rsvps_path
  form_scope    = signup_mode ? nil : :rsvp
  submit_label  = signup_mode ? "Start! →" : "RSVP →"
%>
<div class="<%= ["rsvp-form", wrapper_class].compact.join(" ") %>">
  <%= form_with url: form_url, scope: form_scope, method: :post, local: true,
                 data: { controller: "form-submit-once" } do |form| %>
    <div class="rsvp-form__row">
      <%= leading %>
      <div class="input-yellow">
        <div>
          <%= form.email_field :email, placeholder: placeholder, autocomplete: "email", required: true, value: @prefill_email %>
        </div>
      </div>

      <%= form.button type: "submit", class: "rsvp-form__submit" do %>
        <div><%= submit_label %></div>
      <% end %>

      <%= trailing %>
    </div>
  <% end %>
  <%= yield if block_given? %>
</div>
