<%
  display_name = current_user&.display_name.presence
  intro_text = display_name ? "Welcome, @#{display_name}" : "Welcome!"

  steps = [
    {
      intro: true,
      ceremonial: true,
      text: intro_text,
      subtitle: "to the Stardance Challenge",
      autoAdvance: 3200
    },
    {
      selector: ".feed-home",
      excludeTop: ".empty-project-banner, .feed-composer",
      excludeGap: 8,
      text: "Scroll to see what other teens are working on. Leave a like or a comment!",
      padding: 12,
      radius: 12
    },
    {
      selector: ".sidebar__nav",
      text: "Use the sidebar to browse the shop and manage your projects.",
      padding: 12,
      radius: 12
    },
    {
      selector: ".empty-project-banner, .feed-composer",
      text: "When you're ready, create your first project! After you post your first devlog, you can get free stickers!",
      padding: 12,
      radius: 12,
      scrollToCenter: true
    }
  ]
%>

<div class="welcome-tour"
     data-controller="welcome-tour"
     data-welcome-tour-steps-value="<%= steps.to_json %>"
     data-welcome-tour-lock-scroll-value="false"
     role="dialog"
     aria-modal="true"
     aria-label="Welcome tour">
  <div class="welcome-tour__overlay" aria-hidden="true"></div>
  <div class="welcome-tour__spotlight"
       data-welcome-tour-target="spotlight"
       aria-hidden="true"></div>

  <div class="welcome-tour__tooltip" data-welcome-tour-target="tooltip">
    <%= inline_svg_tag "icons/tour-arrow.svg",
                       class: "welcome-tour__arrow",
                       aria: { hidden: true },
                       focusable: false %>

    <p class="welcome-tour__text" data-welcome-tour-target="text"></p>
    <p class="welcome-tour__subtitle" data-welcome-tour-target="subtitle" hidden></p>

    <div class="welcome-tour__actions">
      <button type="button"
              class="welcome-tour__back"
              data-welcome-tour-target="back"
              data-action="click->welcome-tour#back"
              hidden>
        Back
      </button>
      <button type="button"
              class="welcome-tour__next"
              data-welcome-tour-target="next"
              data-action="click->welcome-tour#next">
      </button>
    </div>

    <span class="welcome-tour__counter"
          data-welcome-tour-target="counter"
          aria-hidden="true"></span>
  </div>
</div>
