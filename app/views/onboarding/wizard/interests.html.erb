<% content_for :title, "Interests" %>
<main class="onboarding-screen onboarding-screen--interests" data-controller="onboarding-transition">
  <%= render Onboarding::ProgressBarComponent.new(step: :interests) %>

  <div class="onboarding-screen__content">
    <p class="onboarding-screen__eyebrow">ok anywayssss</p>
    <h1 class="onboarding-screen__title">What kind of stuff are you interested in?</h1>
    <p class="onboarding-screen__subhead">Pick as many as you want! This helps us find resources and cool stuff that are right for you.</p>

    <%= form_with url: onboarding_interests_path, method: :post,
                   data: { controller: "onboarding-interests", action: "change->onboarding-interests#toggle" },
                   class: "onboarding-interests__form" do |f| %>
      <% interest_art = {
           "web_dev" => "web", "hardware" => "hardware", "app_dev" => "app",
           "game_dev" => "game", "ai_ml" => "ai", "art_design" => "art"
         } %>
      <div class="onboarding-interests__grid">
        <% User::ALLOWED_INTERESTS.each do |slug| %>
          <% prefix = interest_art[slug] %>
          <label class="onboarding-interests__tile">
            <%= check_box_tag "interests[]", slug, @selected.include?(slug),
                              class: "onboarding-interests__checkbox",
                              data: { onboarding_interests_target: "interest" } %>
            <span class="onboarding-interests__art" aria-hidden="true">
              <%= image_tag "onboarding/#{prefix}1.png", class: "onboarding-interests__art-shape onboarding-interests__art-shape--a" %>
              <%= image_tag "onboarding/#{prefix}2.png", class: "onboarding-interests__art-shape onboarding-interests__art-shape--b" %>
              <%= image_tag "onboarding/#{prefix}3.png", class: "onboarding-interests__art-shape onboarding-interests__art-shape--c" %>
            </span>
            <span class="onboarding-interests__label"><%= User::INTEREST_LABELS[slug] %></span>
          </label>
        <% end %>
        <label class="onboarding-interests__tile onboarding-interests__tile--unknown">
          <%= check_box_tag "interests[]", User::INTERESTS_UNKNOWN,
                            @selected == [ User::INTERESTS_UNKNOWN ],
                            class: "onboarding-interests__checkbox",
                            data: { onboarding_interests_target: "unknown" } %>
          <span class="onboarding-interests__label">I'm not sure yet. I wanna see everything!</span>
        </label>
        <%= render ActionButtonComponent.new(
              text: "Next",
              variant: :primary,
              size: :large,
              type: :submit,
              icon: "icons/right-arrow.svg",
              disabled: @selected.empty?,
              class: "onboarding-interests__submit",
              data: {
                onboarding_interests_target: "submit",
                action: "click->onboarding-transition#press"
              }
            ) %>
      </div>
    <% end %>
  </div>
</main>
