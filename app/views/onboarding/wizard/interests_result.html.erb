<% content_for :title, "Other teens like you" %>
<main class="onboarding-screen onboarding-screen--interests-result" data-controller="onboarding-transition">
  <%= render Onboarding::ProgressBarComponent.new(step: :interests_result) %>

  <div class="onboarding-screen__content">
    <% if @interests == [ User::INTERESTS_UNKNOWN ] %>
      <h1 class="onboarding-screen__title">That's alright!</h1>
      <p class="onboarding-screen__subhead">We'll figure it out together :D</p>
    <% else %>
      <h1 class="onboarding-screen__title">
        <% if @peer_count >= 10 %>
          <%= onboarding_count_up(@peer_count) %> other teens like that too!
        <% else %>
          A bunch of other teens like that too!
        <% end %>
      </h1>
      <p class="onboarding-screen__subhead">
        <% if @beginner_peer_count >= 10 %>
          and <%= onboarding_count_up(@beginner_peer_count) %> of them are also beginners!
        <% else %>
          and plenty of them are also beginners!
        <% end %>
      </p>

      <% if @featured_projects.present? %>
        <div class="onboarding-interests-result__featured" aria-label="Featured projects">
          <% @featured_projects.each do |project| %>
            <a href="<%= project.url %>" target="_blank" rel="noopener noreferrer" class="onboarding-interests-result__featured-card">
              <%= image_tag project.thumbnail_url, alt: project.title, class: "onboarding-interests-result__featured-img", loading: "lazy" %>
              <div class="onboarding-interests-result__featured-info">
                <strong class="onboarding-interests-result__featured-title"><%= project.title %></strong>
                <span class="onboarding-interests-result__featured-meta"><%= project.age %>yo from <%= project.location %></span>
              </div>
            </a>
          <% end %>
        </div>
      <% end %>

      <p class="onboarding-interests-result__prize-label">and they're getting prizes like</p>
      <div class="onboarding-interests-result__prizes" aria-hidden="true">
        <%# v1 ships with placeholder boxes; curated photos go in app/assets/images/onboarding/prizes/ once extracted from Figma %>
        <% 5.times do |i| %>
          <div class="onboarding-interests-result__prize onboarding-interests-result__prize--<%= i %>"></div>
        <% end %>
      </div>
    <% end %>

    <%= render ActionButtonComponent.new(
          text: "Next",
          variant: :primary,
          size: :large,
          href: onboarding_name_path,
          icon: "icons/right-arrow.svg",
          data: { action: "click->onboarding-transition#leave" }
        ) %>
  </div>
</main>
