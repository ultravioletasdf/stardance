<% content_for :title, "Birthday" %>
<main class="onboarding-screen onboarding-screen--birthday" data-controller="onboarding-transition">
  <%= render Onboarding::ProgressBarComponent.new(step: :birthday) %>

  <div class="onboarding-screen__content">
    <h1 class="onboarding-screen__title">How old are you?</h1>
    <p class="onboarding-screen__subhead">Stardance is only for teens aged 13–18, and is run by Hack Club, a nonprofit for teens, by teens.</p>

    <%= form_with url: onboarding_birthday_path, method: :post,
                   class: "onboarding-birthday__form" do %>
      <div class="onboarding-birthday__cards">
        <%= render Onboarding::ChoiceCardComponent.new(name: "attestation", value: "teen_13_18") do %>
          I'm a teen aged 13–18!
        <% end %>
        <%= render Onboarding::ChoiceCardComponent.new(name: "attestation", value: "ineligible") do %>
          I'm not a teen. (19+)
        <% end %>
      </div>
    <% end %>
  </div>
</main>
